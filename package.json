{
  "name": "developer-os",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=@developer-os/web --filter=@developer-os/storybook",
    "build": "turbo build --filter=@developer-os/web --filter=@developer-os/storybook",
    "lint": "turbo lint && prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,mdx,yml,yaml}\"",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,mdx,yml,yaml}\"",
    "test": "turbo test",
    "storybook": "pnpm --filter @developer-os/storybook dev",
    "build-storybook": "pnpm --filter @developer-os/storybook build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.53.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,mdx,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
